# /etc/default/drpow
# Runtime owner and source path
# These are auto-set by scripts/install_systemd_drpow.sh.
RUN_AS_USER=
DRPOW_SRC_DIR=

# Node runtime (consumed by scripts/start_testnet.sh)
DRPOW_HOME=
BIND_PORT=29101
PUBLIC_ENDPOINT=85.217.171.168:29101
SEED_PEER=
AUTOPROPOSE=1
AUTOPROPOSE_INTERVAL_SEC=20
POW_TARGET_PREFIX_BYTES=2
LOG_LEVEL=normal

# Optional overrides
# DATA_DIR=/path/to/.drpow/nodes/testnet_29101
# KEY_FILE=/path/to/.drpow/keys/node_signer_privkey.hex
# PEERS_FILE=/path/to/.drpow/nodes/testnet_29101/peers.txt
