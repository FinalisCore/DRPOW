# /etc/default/drpow
# Runtime owner and source path
RUN_AS_USER=greendragon
DRPOW_SRC_DIR=/home/greendragon/Desktop/coin/src

# Node runtime (consumed by scripts/start_testnet.sh)
DRPOW_HOME=/home/greendragon/.drpow
BIND_PORT=29101
PUBLIC_ENDPOINT=85.217.171.168:29101
SEED_PEER=
AUTOPROPOSE=1
AUTOPROPOSE_INTERVAL_SEC=20
POW_TARGET_PREFIX_BYTES=2
LOG_LEVEL=normal

# Optional overrides
# DATA_DIR=/home/greendragon/.drpow/nodes/testnet_29101
# KEY_FILE=/home/greendragon/.drpow/keys/node_signer_privkey.hex
# PEERS_FILE=/home/greendragon/.drpow/nodes/testnet_29101/peers.txt
